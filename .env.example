# Copy to .env.local for local dev; set the same variables in Vercel for prod.

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client (see docs/learning-center-setup.md)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# The single email allowed through the gate
AUTH_ALLOWED_EMAIL=

# Neon Postgres connection string
DATABASE_URL=
